#!/bin/sh
# Verity pre-push hook (opt-in).
#
# This hook is NOT installed automatically. To enable it in a local
# clone:
#
#     git config core.hooksPath .githooks
#
# The hook is a convenience only — the authoritative gate is
# GitHub Actions (see .github/workflows/ci.yml) running
# `python3 tools/verify_repo.py --require-clean`. If you skip this
# hook, CI still catches problems.
#
# If Python is not available or verify_repo.py cannot run, the hook
# prints a warning and lets the push proceed; CI is authoritative.

set -eu

if command -v python3 >/dev/null 2>&1; then
  PY=python3
elif command -v python >/dev/null 2>&1; then
  PY=python
else
  echo "verify_repo pre-push: python not found; skipping (CI still runs)." >&2
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
if [ ! -f "$REPO_ROOT/tools/verify_repo.py" ]; then
  echo "verify_repo pre-push: tools/verify_repo.py missing; skipping." >&2
  exit 0
fi

echo "[verify_repo pre-push] running local gate..." >&2
if ! (cd "$REPO_ROOT" && "$PY" tools/verify_repo.py --require-clean); then
  echo "" >&2
  echo "verify_repo pre-push: FAIL. Push aborted." >&2
  echo "To bypass in an emergency: git push --no-verify (CI still runs)." >&2
  exit 1
fi

exit 0
